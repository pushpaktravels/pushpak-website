# ============================================================
# Pushpak Portal — environment variables
# Copy this file to `.env` for local dev, and add the same keys
# to Vercel → Project → Settings → Environment Variables for prod.
# NEVER commit the real .env to git.
# ============================================================

# ── Postgres (Supabase) ────────────────────────────────────────
# Get from Supabase: Project Settings → Database → Connection string → "Transaction" pooler
# (Use the pooler URL, not the direct URL — Vercel serverless needs pooling)
DATABASE_URL="postgresql://postgres.PROJECTREF:[email protected]:6543/postgres?pgbouncer=true"
# Direct URL — used by prisma migrate (bypass pooler for DDL)
DIRECT_URL="postgresql://postgres.PROJECTREF:[email protected]:5432/postgres"

# ── JWT signing key ────────────────────────────────────────────
# Generate with: openssl rand -hex 64
# Rotate this if ever leaked — all sessions are invalidated.
JWT_SECRET="paste-a-128-char-hex-string-here-after-running-openssl-rand-hex-64"

# ── Argon2 password hashing pepper ─────────────────────────────
# Extra secret mixed into every password hash. If DB leaks, an attacker
# still can't brute-force without this. Generate same way as JWT_SECRET.
PASSWORD_PEPPER="another-128-char-hex-string"

# ── TOTP (2FA) issuer name shown in Authenticator apps ─────────
TOTP_ISSUER="Pushpak Portal"

# ── Resend (transactional email) ───────────────────────────────
# Sign up at resend.com — free tier covers ~3000 emails/month
RESEND_API_KEY="re_..."
RESEND_FROM="Pushpak Portal <[email protected]>"

# ── Public URL (used in emails for password reset links etc.) ──
NEXT_PUBLIC_APP_URL="https://app.flypushpak.com"

# ── Migration script (one-time, reading existing Sheet) ────────
# Path to a Google Cloud service account JSON file with Sheets API access.
# After migration is done, you can remove these.
GOOGLE_SERVICE_ACCOUNT_KEY=""
LEGACY_SHEET_ID="1h3cH6KyRiyctWvD2c7cPfoQhAgdRzULFoaaT1hfzOTI"
